PORT=5050
DEFAULT_CART_ID=default
PRODUCT_DATA_SOURCE=auto
PRODUCT_FETCH_TIMEOUT_MS=1200
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/shoppingDB?retryWrites=true&w=majority

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# AI assistant
# Put AI keys in server/.env only. client/.env is only for Vite/Firebase values.
# Gemini powers voice transcription in the fallback recorder flow.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash

# Optional compatibility settings
# If GEMINI_API_KEY is missing, voice transcription can fall back to OpenAI when configured.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Order emails
SEND_ORDER_EMAILS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourname@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
SMTP_FROM="Powered Shopping <yourname@gmail.com>"
